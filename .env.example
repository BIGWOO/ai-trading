# Binance Testnet API Keys
# 從 https://testnet.binance.vision/ 取得
BINANCE_API_KEY=your_api_key_here
BINANCE_SECRET_KEY=your_secret_key_here

# 使用測試網（不要改成 false，除非你真的要用真錢！）
BINANCE_TESTNET=true

# 測試網 API 端點（不需要修改）
# 只允許 https://testnet.binance.vision 和 https://api.binance.com
BINANCE_BASE_URL=https://testnet.binance.vision
BINANCE_WS_URL=wss://testnet.binance.vision/ws

# ===== Mainnet 安全保護 =====
# 非測試網時，必須設定此值才能下單（防止誤操作）
# LIVE_TRADING_CONFIRM=yes-i-know-what-i-am-doing

# 非測試網時，單筆下單金額上限（USDT），預設 100
# MAX_ORDER_USDT=100
